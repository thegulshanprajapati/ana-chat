# Backend environment variables (Render / local)
# Copy to `backend/.env` (local) or set these in Render "Environment" settings.

# Server
NODE_ENV=production
PORT=5000

# CORS (comma-separated)
# Example:
# CLIENT_ORIGIN=https://chat.myana.site,https://www.chat.myana.site,http://localhost:5173
CLIENT_ORIGIN=

# Database
MONGODB_URI=

# Auth / JWT
# IMPORTANT: set a strong secret in production
JWT_SECRET=
ACCESS_TOKEN_TTL=15m
ADMIN_TOKEN_TTL=7d

# Cookies
# Render is HTTPS => keep secure cookies enabled
FORCE_SECURE_COOKIES=true

# Sessions / device limits
MAX_ACTIVE_DEVICES=4

# Admin backdoor (optional)
# If you want to login as admin using mobile + fixed password in the code,
# set this to that mobile number (e.g. 8709131702). Otherwise leave empty.
ADMIN_BACKDOOR_MOBILE=

# Google OAuth (optional)
# Comma-separated list of Google client IDs
GOOGLE_CLIENT_IDS=

# SMS provider (optional)
FAST2SMS_API_KEY=

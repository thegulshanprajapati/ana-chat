# AnaChat Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb+srv://anachat:anachat123@cluster0.ylyxc5r.mongodb.net/anachat?retryWrites=true&w=majority
MONGO_DB_NAME=anachat

# Authentication
JWT_SECRET=your_jwt_secret_key_change_in_production
SUPER_ADMIN=8709131702
ACCESS_TOKEN_TTL=15m
ADMIN_TOKEN_TTL=7d

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id

# CORS Configuration (allow frontend origins)
CLIENT_ORIGIN=https://chat.myana.site,https://www.chat.myana.site,http://localhost:5173,http://localhost:5174

# Redis Configuration (optional for Socket.IO scaling on Render)
# REDIS_URL=redis://localhost:6379

# SMS/Messaging Service (optional)
# FAST2SMS_API_KEY=your_api_key
# FAST2SMS_SENDER_ID=ANACHAT
# DLT_WEBHOOK_SECRET=your_webhook_secret

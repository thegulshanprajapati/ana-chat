# ============================================
# ANACHAT BACKEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values
# For production, generate new secrets and change sensitive values!

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development
# NODE_ENV=production

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Local Development (requires MongoDB running locally):
# MONGODB_URI=mongodb://localhost:27017/anachat

# Production (MongoDB Atlas - get from https://www.mongodb.com/cloud/atlas):
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/anachat?retryWrites=true&w=majority
MONGO_DB_NAME=anachat

# ============================================
# AUTHENTICATION
# ============================================
# Generate new secrets for production! Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_production
ACCESS_TOKEN_TTL=15m
ADMIN_TOKEN_TTL=7d

# Super admin phone number (emergency access)
SUPER_ADMIN=8709131702

# ============================================
# OAUTH CONFIGURATION
# ============================================
# Get from Google Cloud Console: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
# Multiple Google Client IDs (comma-separated):
# GOOGLE_CLIENT_IDS=id1,id2,id3

# ============================================
# CORS CONFIGURATION
# ============================================
# List all frontend origins that can access this backend
# Local: http://localhost:5173, http://localhost:5174, http://localhost:3000
# Production: https://chat.myana.site, https://www.chat.myana.site
CLIENT_ORIGIN=https://chat.myana.site,https://www.chat.myana.site,http://localhost:5173,http://localhost:5174,http://localhost:3000

# ============================================
# SECURITY
# ============================================
# Force secure cookies in production (requires HTTPS)
FORCE_SECURE_COOKIES=false
# FORCE_SECURE_COOKIES=true  # Uncomment for production

# ============================================
# REDIS CONFIGURATION (Optional)
# ============================================
# For Socket.IO horizontal scaling on Render
# Redis is needed only if running multiple backend instances
# Get Redis URL from: https://www.redis.com/ or similar
# REDIS_URL=redis://localhost:6379
# For Render Redis addon, it will be auto-configured

# ============================================
# SMS/MESSAGING SERVICE (Optional)
# ============================================
# Fast2SMS API for OTP and notifications
# Get API key from: https://www.fast2sms.com/
FAST2SMS_API_KEY=your_fast2sms_api_key
FAST2SMS_SENDER_ID=ANACHAT

# DLT (Distributed Learning Technology) webhook
# DLT_WEBHOOK_SECRET=your_dlt_webhook_secret

# ============================================
# DEBUG & LOGGING (Optional)
# ============================================
# Enable detailed logging
# DEBUG=anachat:*

# ============================================
# NOTES FOR PRODUCTION
# ============================================
# 1. Change NODE_ENV to 'production'
# 2. Generate new JWT secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. Set MONGODB_URI to production MongoDB Atlas URI
# 4. Set GOOGLE_CLIENT_ID to production OAuth credentials
# 5. Update CLIENT_ORIGIN with actual frontend domain
# 6. Set FORCE_SECURE_COOKIES=true (requires HTTPS)
# 7. Store all secrets in Render environment variables, NOT in .env file
# 8. Never commit .env file to git - add to .gitignore


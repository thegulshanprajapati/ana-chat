# Backend environment variables for Render, local dev, and secure production
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority
MONGO_DB_NAME=chat_secure
JWT_SECRET=change_this_super_secret
GOOGLE_CLIENT_ID=your_google_client_id
CLIENT_ORIGIN=https://chat.myana.site,https://www.chat.myana.site
REDIS_URL=redis://localhost:6379
NODE_ENV=development

# Additional app-specific keys can be added below
# FAST2SMS_API_KEY=
# FAST2SMS_SENDER_ID=
# DLT_WEBHOOK_SECRET=
# FAST2SMS_MESSAGE_ID=
# FAST2SMS_ROUTE=
# FAST2SMS_VARIABLES_VALUES=
# FAST2SMS_FLASH=

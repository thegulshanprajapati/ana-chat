# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# Local Development - Frontend points to local backend
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# Production - Frontend points to deployed backend (example)
# VITE_API_URL=https://ana-chat.onrender.com/api
# VITE_SOCKET_URL=https://ana-chat.onrender.com

# Google OAuth - Get this from Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Security - Disable devtools in production
VITE_DISABLE_DEVTOOLS=true

# ============================================
# BACKEND ENVIRONMENT VARIABLES (.env in backend/ folder)
# ============================================
# Copy these to backend/.env

# Database
MONGODB_URI=mongodb://localhost:27017/anachat
# For production with MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/anachat

# Frontend Origins (CORS)
CLIENT_ORIGIN=https://chat.myana.site,https://www.chat.myana.site,http://localhost:5173
CLIENT_URL=https://chat.myana.site

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_IDS=your_google_client_id

# JWT Secret (generate a random strong string for production!)
JWT_SECRET=your_jwt_secret_change_this

# SMS Provider (Fast2SMS)
FAST2SMS_API_KEY=your_fast2sms_api_key

# Node Environment
NODE_ENV=development
# NODE_ENV=production

# TURN/STUN for WebRTC
VITE_STUN_URL=stun:stun.l.google.com:19302
VITE_TURN_URL=turn:turn.example.com:3478
VITE_TURN_USERNAME=turnuser
VITE_TURN_CREDENTIAL=turnsecret

# Redis for Socket.IO scaling
REDIS_URL=redis://user:password@host:6379

# Server Port
PORT=5000

# Optional: Force secure cookies in production
# FORCE_SECURE_COOKIES=true

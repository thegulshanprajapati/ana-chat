unded-lg bg-rose-600 px-2.5 py-1.5 text-[11px] font-semibold text-white shadow-sm transition hover:bg-rose-700\"\n                      >\n                        Delete\n                      </button>\n                    </div>\n                  </div>\n                )}\n\n                {!deleteConfirm && (\n                  <div className=\"grid grid-cols-1 gap-1\">\n                  <MenuButton\n                    icon={<CheckSquare size={13} />}\n                    label={selected ? \"Unselect\" : \"Select\"}\n                    onClick={() => {\n                      onSelectToggle?.(message);\n                      setMenuOpen(false);\n                    }}\n                  />\n                  <MenuButton\n                    icon={<CornerUpLeft size={13} />}\n                    label=\"Reply\"\n                    onClick={() => {\n                      onReply?.(message);\n                      setMenuOpen(false);\n                    }}\n                  />\n                  {message.body && <MenuButton icon={<Copy size={13} />} label=\"Copy\" onClick={handleCopy} />}\n                  {canEdit && <MenuButton icon={<Pencil size={13} />} label=\"Edit\" onClick={handleEdit} />}\n                  <MenuButton\n                    icon={<Star size={13} />}\n                    label={message.my_starred ? \"Unstar\" : \"Star\"}\n                    onClick={() => {\n                      onToggleStar?.(message);\n                      setMenuOpen(false);\n                    }}\n                  />\n                  {canForward && (\n                    <MenuButton\n                      icon={<Forward size={13} />}\n                      label=\"Forward\"\n                      onClick={() => {\n                        onForward?.(message);\n                        setMenuOpen(false);\n                      }}\n                    />\n                  )}\n                  {(isImage || isVideo || isPdf) && (\n                    <>\n    
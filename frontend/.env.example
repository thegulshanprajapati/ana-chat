# AnaChat Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# LOCAL DEVELOPMENT
# ============================================
# Uncomment below for local development:
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# ============================================
# PRODUCTION (Render Backend + Vercel Frontend)
# ============================================
# Use these for production (example values):
# VITE_API_URL=https://api.chat.myana.site/api
# VITE_SOCKET_URL=https://api.chat.myana.site

# If your backend API is hosted separately, keep the API and socket URLs consistent
# and always use https:// in production.

# ============================================
# OAuth Configuration
# ============================================
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# ============================================
# Security Settings
# ============================================
VITE_DISABLE_DEVTOOLS=true
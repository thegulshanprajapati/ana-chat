# Frontend environment variables (Vercel / local)
# Copy to `frontend/.env` (local) or set these in your hosting provider env vars.

# API base URL (must include /api)
VITE_API_URL=https://api.chat.myana.site/api

# Socket base URL (same backend host, without /api)
VITE_SOCKET_URL=https://api.chat.myana.site

# Google OAuth (optional)
VITE_GOOGLE_CLIENT_ID=

# Production hardening (optional)
VITE_DISABLE_DEVTOOLS=true

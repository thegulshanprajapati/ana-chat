{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.chat.myana.site/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://api.chat.myana.site/socket.io/:path*"
    },
    {
      "source": "^/(.*)$",
      "destination": "/index.html"
    }
  ]
}

{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://api.chat.myana.site/api/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://api.chat.myana.site/socket.io/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

{
  "name": "chat-app-root",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm --prefix frontend run dev",
    "dev:server": "npm --prefix backend run dev",
    "db:init": "npm --prefix backend run db:init",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "preview": "npm --prefix frontend run preview",
    "postinstall": "npm --prefix backend install && npm --prefix frontend install"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0"
  }
}
